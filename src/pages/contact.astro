---
import { Phone, MessageCircle, Mail } from 'lucide-react';
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import Card from '../components/Card.astro';
import ContactForm from '../components/ContactForm.jsx';
import { createBreadcrumbList } from '../utils/structuredData';

const bcItems = [{ label: 'お問い合わせ・無料見積り' }];
const jsonLd = createBreadcrumbList([{ label: 'ホーム', path: '/' }, ...bcItems]);
---

<BaseLayout title="お問い合わせ・無料見積り" description="建築鈑金はたへのお問い合わせ・無料見積りはこちら。電話・LINE・メールフォームで24時間受付中。相見積もり歓迎、しつこい営業はいたしません。" jsonLd={jsonLd}>
  <div class="animate-fade-in pt-20">
    <div class="bg-emerald-800 text-white py-16 px-4 text-center">
      <h1 class="text-3xl md:text-5xl font-bold mb-4">
        お問い合わせ・無料見積り
      </h1>
      <p class="text-xl text-emerald-100">
        相見積もり歓迎。しつこい営業はいたしません。
      </p>
    </div>
    <Breadcrumb items={bcItems} />

    <div class="container mx-auto max-w-4xl py-16 px-4">
      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <a href="tel:000-000-0000" class="block">
          <Card class="text-center border-t-8 border-t-orange-500 hover:shadow-xl transition-shadow cursor-pointer h-full">
            <Phone className="w-16 h-16 text-orange-500 mx-auto mb-4" />
            <h2 class="text-2xl font-bold text-slate-800 mb-2">
              お電話でのご相談
            </h2>
            <p class="text-slate-600 mb-4">
              お急ぎの方、直接話したい方はこちら
            </p>
            <div class="text-4xl font-extrabold text-orange-600 mb-2 tracking-wider">
              000-000-0000
            </div>
            <p class="text-sm text-slate-500">
              営業時間 8:00〜18:00 (日祝休)
            </p>
          </Card>
        </a>

        <Card class="text-center border-t-8 border-t-line-green hover:shadow-xl transition-shadow cursor-pointer">
          <MessageCircle className="w-16 h-16 text-line-green mx-auto mb-4" />
          <h2 class="text-2xl font-bold text-slate-800 mb-2">
            LINEで写真相談
          </h2>
          <p class="text-slate-600 mb-4">
            スマホで屋根の写真を送るだけで簡易診断！
          </p>
          <Button variant="line" class="w-full text-xl py-4 shadow-line-green/50">
            友だち追加して相談
          </Button>
          <p class="text-sm text-slate-500 mt-2">24時間受付中</p>
        </Card>
      </div>

      <div class="bg-slate-50 p-8 rounded-xl border border-slate-200">
        <h2 class="text-2xl font-bold text-emerald-900 mb-6 flex items-center">
          <Mail className="mr-2" /> メールフォーム（24時間受付）
        </h2>
        <ContactForm client:load />
      </div>
    </div>
  </div>
</BaseLayout>
