---
import { Clock, Phone, Award, Users, Shield } from 'lucide-react';
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CTABanner from '../components/CTABanner.astro';
import Card from '../components/Card.astro';
import { company } from '../data/company';
import { createBreadcrumbList } from '../utils/structuredData';

const bcItems = [{ label: '会社案内' }];
const jsonLd = createBreadcrumbList([{ label: 'ホーム', path: '/' }, ...bcItems]);

const companyInfo = [
  ['屋号', company.name],
  ['代表者', company.representative],
  ['電話番号', company.phone],
  ['営業時間', `${company.hours}（${company.closed}）`],
  ['事業内容', '屋根工事・外壁工事・雨樋工事・板金工事全般'],
  ['対応エリア', company.areas.join(' / ')],
];
---

<BaseLayout title="会社案内" description="建築鈑金はたの会社案内。福井県を中心に屋根・外壁・雨樋リフォームを手がける地域密着の建築板金店です。代表挨拶、資格・実績、対応エリアをご紹介。" jsonLd={jsonLd}>
  <div class="animate-fade-in pt-20">
    <div class="bg-emerald-800 text-white py-16 px-4 text-center">
      <h1 class="text-3xl md:text-5xl font-bold mb-4">会社案内</h1>
      <p class="text-xl text-emerald-100">
        地域密着・誠実施工の建築板金店
      </p>
    </div>
    <Breadcrumb items={bcItems} />

    <div class="container mx-auto max-w-4xl py-16 px-4 space-y-16">
      {/* 会社概要 */}
      <section>
        <h2 class="text-2xl md:text-3xl font-bold text-emerald-900 mb-8 text-center">
          会社概要
        </h2>
        <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
          <table class="w-full">
            <tbody class="divide-y divide-slate-200">
              {companyInfo.map(([label, value]) => (
                <tr>
                  <th class="bg-emerald-50 text-emerald-900 font-bold text-sm p-4 w-1/3 text-left align-top">
                    {label}
                  </th>
                  <td class="p-4 text-slate-700 text-sm">{value}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      {/* 代表者の声 */}
      <section>
        <h2 class="text-2xl md:text-3xl font-bold text-emerald-900 mb-8 text-center">
          代表者の声
        </h2>
        <div class="bg-white p-8 rounded-xl border border-slate-200">
          <div class="md:flex md:gap-8">
            <img
              src="/representative.webp"
              alt="代表 畑 直幸"
              width="160"
              height="192"
              class="w-40 h-48 rounded-lg mx-auto md:mx-0 mb-6 md:mb-0 shrink-0 object-cover"
            />
            <div class="space-y-4 text-slate-700 leading-relaxed">
              <p>
                建築鈑金はたのページをご覧いただき、ありがとうございます。<br />
                代表の畑 直幸（ハタ ナオユキ）です。
              </p>
              <p>
                私がこの仕事をしていて一番うれしいのは、お客様と「顔の見える関係」で
                つながれることです。屋根や雨樋のことって、誰に相談すればいいか
                わからないですよね。だからこそ、「あ、畑さんに聞いてみよう」と
                気軽に思い出してもらえる存在でありたいと思っています。
              </p>
              <p>
                大きな会社のような派手さはありませんが、人と人とのつながりを大事にして、
                一棟一棟、自分の家だと思って丁寧に施工しています。
                屋根のことで少しでも気になることがあれば、どうぞお気軽にお声がけください。
              </p>
              <p class="font-bold text-emerald-800">
                福井の皆さまの「困った」に、まっすぐ向き合います。
              </p>
            </div>
          </div>
        </div>
      </section>

      {/* 資格・実績 */}
      <section>
        <h2 class="text-2xl md:text-3xl font-bold text-emerald-900 mb-8 text-center">
          当店の強み
        </h2>
        <div class="grid md:grid-cols-3 gap-6">
          <Card class="text-center border-t-4 border-t-emerald-500">
            <Shield className="w-12 h-12 text-emerald-600 mx-auto mb-4" />
            <h3 class="font-bold text-lg text-emerald-900 mb-2">
              鈑金職人の技術
            </h3>
            <p class="text-slate-600 text-sm">
              建築板金技能士・職業訓練指導員の資格を持つ職人が直接施工。
              雨仕舞いの技術で確実な防水を実現します。
            </p>
          </Card>
          <Card class="text-center border-t-4 border-t-emerald-500">
            <Users className="w-12 h-12 text-emerald-600 mx-auto mb-4" />
            <h3 class="font-bold text-lg text-emerald-900 mb-2">
              一括提案で費用削減
            </h3>
            <p class="text-slate-600 text-sm">
              屋根・外壁・雨樋をまとめてご提案。足場の共有で
              20〜30万円の節約が可能です。
            </p>
          </Card>
          <Card class="text-center border-t-4 border-t-emerald-500">
            <Award className="w-12 h-12 text-emerald-600 mx-auto mb-4" />
            <h3 class="font-bold text-lg text-emerald-900 mb-2">
              地域密着の安心感
            </h3>
            <p class="text-slate-600 text-sm">
              福井県内で地域に根ざした営業。工事後のアフターフォローも
              迅速に対応いたします。
            </p>
          </Card>
        </div>
      </section>

      {/* 営業時間・お問い合わせ */}
      <section>
        <h2 class="text-2xl md:text-3xl font-bold text-emerald-900 mb-8 text-center">
          営業時間・お問い合わせ
        </h2>
        <div class="bg-white p-8 rounded-xl border border-slate-200">
          <div class="space-y-4">
            <div class="flex items-center">
              <Clock className="w-6 h-6 text-emerald-600 mr-3 shrink-0" />
              <span class="text-slate-700">
                {company.hours}（{company.closed}）
              </span>
            </div>
            <div class="flex items-center">
              <Phone className="w-6 h-6 text-emerald-600 mr-3 shrink-0" />
              <a href={`tel:${company.phone}`} class="text-emerald-700 font-bold hover:text-emerald-900 transition-colors">
                {company.phone}
              </a>
            </div>
          </div>
        </div>
      </section>

      {/* 対応エリア */}
      <section>
        <h2 class="text-2xl md:text-3xl font-bold text-emerald-900 mb-8 text-center">
          対応エリア
        </h2>
        <div class="bg-emerald-50 p-8 rounded-xl border border-emerald-200">
          <div class="flex flex-wrap gap-3 justify-center mb-4">
            {company.areas.map((area) => (
              <span class="bg-white px-4 py-2 rounded-full border border-emerald-300 font-bold text-emerald-800 text-sm">
                {area}
              </span>
            ))}
          </div>
          <p class="text-center text-sm text-emerald-700">
            ※上記以外のエリアもお気軽にご相談ください。
          </p>
        </div>
      </section>
    </div>

    <CTABanner />
  </div>
</BaseLayout>
