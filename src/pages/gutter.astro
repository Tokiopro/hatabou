---
import { Droplets, AlertTriangle, CheckCircle } from 'lucide-react';
import ServicePageLayout from '../layouts/ServicePageLayout.astro';
import Card from '../components/Card.astro';
import { faqData } from '../data/faq';

const symptoms = [
  { title: '雨樋からの水漏れ', desc: '継ぎ目の劣化やひび割れにより、雨水が途中で漏れてしまう状態。' },
  { title: '雨樋の変形・たわみ', desc: '雪の重みや経年劣化で雨樋が歪み、正常に排水できなくなっている状態。' },
  { title: '雨樋の外れ・落下', desc: '金具の劣化や大雪で雨樋が外れ、機能していない状態。早急な対応が必要です。' },
  { title: '雨樋の詰まり', desc: '落ち葉やゴミが詰まり、水があふれている状態。外壁への雨水直撃の原因に。' },
];

const comparison = [
  {
    type: '部分修理',
    price: '数万円〜',
    period: '半日〜1日',
    points: ['一部分の破損・外れの場合', '金具の交換や補修で対応', 'コストを抑えたい方に'],
  },
  {
    type: '全交換',
    price: '20〜30万円',
    period: '1〜2日',
    points: ['全体的に劣化が進んでいる場合', '排水性能を完全に回復', '新しい雨樋で長期間安心'],
  },
];
---

<ServicePageLayout
  title="雨樋工事"
  subtitle="部分修理から全交換まで、雨樋のお悩みを解決"
  seoTitle="雨樋工事"
  seoDescription="福井県の雨樋修理・交換は建築鈑金はた。雪による破損、水漏れ、詰まりに迅速対応。部分修理は数万円〜、全交換は20〜30万円。無料点検実施中。"
  serviceName="雨樋工事"
  priceRange="20〜30万円"
  breadcrumbItems={[{ label: '雨樋工事' }]}
  faqItems={faqData.gutter.items}
>
  {/* 結論ボックス */}
  <div class="bg-emerald-50 border-l-4 border-emerald-600 p-6 rounded-r-lg">
    <p class="text-lg text-slate-800 leading-relaxed">
      <strong class="text-emerald-800">結論：</strong>
      雨樋の破損を放置すると、外壁の劣化・基礎の浸水・シロアリの原因になります。
      部分修理なら数万円から対応可能。全交換でも20〜30万円が目安です。
    </p>
  </div>

  {/* よくある症状 */}
  <section>
    <h2 class="text-2xl md:text-3xl font-bold text-emerald-900 mb-6 flex items-center justify-center">
      <Droplets className="w-8 h-8 text-blue-500 mr-3" />
      よくある症状
    </h2>
    <div class="grid md:grid-cols-2 gap-6">
      {symptoms.map((symptom) => (
        <Card class="border-l-4 border-l-blue-400">
          <h3 class="font-bold text-lg text-slate-800 mb-2">
            {symptom.title}
          </h3>
          <p class="text-slate-600 text-sm">{symptom.desc}</p>
        </Card>
      ))}
    </div>
  </section>

  {/* 修理 vs 交換 */}
  <section>
    <h2 class="text-2xl md:text-3xl font-bold text-emerald-900 mb-8 text-center">
      修理と交換、どちらが最適？
    </h2>
    <div class="grid md:grid-cols-2 gap-6">
      {comparison.map((item, i) => (
        <Card class={`border-t-4 ${i === 0 ? 'border-t-blue-400' : 'border-t-emerald-500'}`}>
          <h3 class="text-xl font-bold text-emerald-900 mb-3">
            {item.type}
          </h3>
          <div class="mb-4">
            <p class="text-2xl font-bold text-orange-600 mb-1">
              {item.price}
            </p>
            <p class="text-sm text-slate-500">工期：{item.period}</p>
          </div>
          <ul class="space-y-2">
            {item.points.map((point) => (
              <li class="flex items-start text-sm text-slate-700">
                <CheckCircle className="w-4 h-4 text-emerald-500 mr-2 mt-0.5 shrink-0" />
                {point}
              </li>
            ))}
          </ul>
        </Card>
      ))}
    </div>
    <div class="mt-6 bg-yellow-50 p-5 rounded-lg border border-yellow-200">
      <p class="text-slate-700 flex items-start">
        <AlertTriangle className="w-5 h-5 text-yellow-600 mr-2 mt-0.5 shrink-0" />
        <span>
          <strong>福井の大雪による破損</strong>にも迅速に対応しています。
          雨樋が外れたまま放置すると、外壁や基礎への被害が拡大します。
          お早めにご相談ください。
        </span>
      </p>
    </div>
  </section>

  {/* 放置のリスク */}
  <section>
    <h2 class="text-2xl md:text-3xl font-bold text-emerald-900 mb-6 text-center">
      雨樋を放置するリスク
    </h2>
    <div class="bg-red-50 border border-red-200 rounded-xl p-6 md:p-8">
      <div class="grid md:grid-cols-3 gap-6">
        <div class="text-center">
          <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-3">
            <span class="text-3xl">🏠</span>
          </div>
          <h3 class="font-bold text-red-800 mb-1">外壁の劣化</h3>
          <p class="text-sm text-slate-600">
            雨水が直接外壁にかかり、塗装や外壁材の劣化が加速します。
          </p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-3">
            <span class="text-3xl">💧</span>
          </div>
          <h3 class="font-bold text-red-800 mb-1">基礎の浸水</h3>
          <p class="text-sm text-slate-600">
            排水されない雨水が基礎周りに溜まり、基礎の劣化や床下浸水の原因に。
          </p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-3">
            <span class="text-3xl">🐛</span>
          </div>
          <h3 class="font-bold text-red-800 mb-1">シロアリの発生</h3>
          <p class="text-sm text-slate-600">
            湿気が溜まりやすくなり、シロアリが発生するリスクが高まります。
          </p>
        </div>
      </div>
    </div>
  </section>
</ServicePageLayout>
