---
import { AlertTriangle, ShieldAlert, CheckCircle } from 'lucide-react';
import ServicePageLayout from '../layouts/ServicePageLayout.astro';
import Card from '../components/Card.astro';
import { faqData } from '../data/faq';

const emergencySigns = [
  '天井にシミやカビがある',
  '雨の日に壁や窓枠が濡れる',
  'クロス（壁紙）が浮いている・剥がれている',
  '天井裏からポタポタ音がする',
  '屋根材にヒビや欠けが見える',
];

const causes = [
  {
    title: '屋根材の劣化',
    desc: 'コロニアルのひび割れ、瓦のズレ、板金の錆びなど。築15年以上で発生しやすくなります。',
  },
  {
    title: '板金部分の浮き・劣化',
    desc: '棟板金や谷樋の劣化が原因で雨水が侵入するケースが非常に多いです。',
  },
  {
    title: 'コーキング（シーリング）の劣化',
    desc: '窓回りや外壁の継ぎ目の防水材が経年劣化し、隙間から雨水が浸入します。',
  },
  {
    title: '雨樋の詰まり・破損',
    desc: '雨樋が機能しないと、水が屋根や外壁に直接かかり、雨漏りの原因になります。',
  },
];

const steps = [
  { step: '01', title: 'お問い合わせ', desc: '電話・LINE・フォームからお気軽にご連絡ください。緊急の場合はお電話がスムーズです。' },
  { step: '02', title: '現地調査・原因特定', desc: '屋根に上り（またはドローンで）、雨漏りの原因箇所を目視・散水試験で特定します。' },
  { step: '03', title: 'お見積り・修理方針ご説明', desc: '写真をご覧いただきながら、状況と最適な修理方法、お見積りをご説明します。' },
  { step: '04', title: '修理施工', desc: '原因に応じた確実な修理を実施。鈑金職人の雨仕舞い技術で再発を防ぎます。' },
  { step: '05', title: '完了確認', desc: 'お客様と一緒に仕上がりを確認。修理後のメンテナンスについてもアドバイスいたします。' },
];
---

<ServicePageLayout
  title="雨漏り修理"
  subtitle="福井の雨・雪から、あなたの家を守ります"
  seoTitle="雨漏り修理"
  seoDescription="福井県の雨漏り修理は建築鈑金はたにお任せください。鈑金職人の雨仕舞い技術で原因を特定し確実に修理。無料点検・お見積り実施中。"
  serviceName="雨漏り修理"
  priceRange="要現地調査"
  breadcrumbItems={[{ label: '雨漏り修理' }]}
  faqItems={faqData.leak.items}
>
  {/* 結論ボックス */}
  <div class="bg-emerald-50 border-l-4 border-emerald-600 p-6 rounded-r-lg">
    <p class="text-lg text-slate-800 leading-relaxed">
      <strong class="text-emerald-800">結論：</strong>
      雨漏りは放置するほど修理費用が膨らみます。
      建築鈑金はたでは鈑金職人の「雨仕舞い」技術で原因を特定し、確実に雨漏りを止めます。
      まずは無料点検で状態を確認しましょう。
    </p>
  </div>

  {/* 緊急症状チェック */}
  <section>
    <h2 class="text-2xl md:text-3xl font-bold text-emerald-900 mb-6 flex items-center justify-center">
      <AlertTriangle className="w-8 h-8 text-red-500 mr-3" />
      こんな症状ありませんか？
    </h2>
    <div class="bg-red-50 border border-red-200 rounded-xl p-6 md:p-8">
      <ul class="space-y-3">
        {emergencySigns.map((sign) => (
          <li class="flex items-start text-lg text-slate-800">
            <ShieldAlert className="w-5 h-5 text-red-500 mr-3 mt-1 shrink-0" />
            {sign}
          </li>
        ))}
      </ul>
      <p class="mt-6 text-red-700 font-bold text-center">
        1つでも当てはまれば、雨漏りが進行している可能性があります。
      </p>
    </div>
  </section>

  {/* 応急処置注意 */}
  <section>
    <h2 class="text-2xl md:text-3xl font-bold text-emerald-900 mb-6 text-center">
      応急処置の注意点
    </h2>
    <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-6 md:p-8">
      <div class="flex items-start">
        <AlertTriangle className="w-8 h-8 text-yellow-600 mr-4 mt-1 shrink-0" />
        <div>
          <p class="text-lg text-slate-800 font-bold mb-2">
            屋根に上るのは大変危険です！
          </p>
          <p class="text-slate-700">
            室内のバケツ設置は問題ありませんが、ブルーシートを掛けるなどの屋根上の作業は
            転落事故のリスクがあります。プロにお任せください。
            当店では緊急時の応急処置にも対応しています。
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* 雨漏りの原因 */}
  <section>
    <h2 class="text-2xl md:text-3xl font-bold text-emerald-900 mb-8 text-center">
      雨漏りの主な原因
    </h2>
    <div class="grid md:grid-cols-2 gap-6">
      {causes.map((cause) => (
        <Card class="border-t-4 border-t-emerald-500">
          <h3 class="text-lg font-bold text-emerald-900 mb-2">
            {cause.title}
          </h3>
          <p class="text-slate-600 text-sm">{cause.desc}</p>
        </Card>
      ))}
    </div>
  </section>

  {/* 対応の流れ */}
  <section>
    <h2 class="text-2xl md:text-3xl font-bold text-emerald-900 mb-8 text-center">
      雨漏り修理の流れ
    </h2>
    <div class="space-y-4">
      {steps.map((item) => (
        <div class="flex items-start bg-white p-5 rounded-lg border border-slate-200">
          <div class="w-10 h-10 bg-emerald-600 text-white rounded-full flex items-center justify-center font-bold text-sm shrink-0 mr-4">
            {item.step}
          </div>
          <div>
            <h3 class="font-bold text-emerald-900 mb-1">
              {item.title}
            </h3>
            <p class="text-slate-600 text-sm">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>
</ServicePageLayout>
