---
import { Home, ArrowLeft } from 'lucide-react';
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
---

<BaseLayout title="ページが見つかりません">
  <div class="animate-fade-in pt-20 min-h-[80vh] flex items-center justify-center px-4">
    <div class="text-center max-w-lg">
      <div class="text-8xl font-extrabold text-emerald-200 mb-4">404</div>
      <h1 class="text-2xl md:text-3xl font-bold text-emerald-900 mb-4">
        ページが見つかりません
      </h1>
      <p class="text-slate-600 mb-8">
        お探しのページは移動または削除された可能性があります。
        URLをお確かめの上、再度お試しください。
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/">
          <Home className="w-5 h-5 mr-2" />
          ホームに戻る
        </Button>
        <Button href="/contact" variant="outline">
          <ArrowLeft className="w-5 h-5 mr-2" />
          お問い合わせ
        </Button>
      </div>
    </div>
  </div>
</BaseLayout>
