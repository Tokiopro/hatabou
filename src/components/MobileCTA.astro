---
import { MessageCircle, Phone } from 'lucide-react';
import { company } from '../data/company';
---

<div class="fixed bottom-0 left-0 w-full z-40 lg:hidden flex shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.1)]">
  <a
    href="/contact"
    class="flex-1 bg-line-green text-white py-3 flex flex-col items-center justify-center font-bold text-xs"
  >
    <MessageCircle className="w-6 h-6 mb-1" />
    LINE相談
  </a>
  <a
    href={`tel:${company.phone}`}
    class="flex-1 bg-orange-600 text-white py-3 flex flex-col items-center justify-center font-bold text-xs"
  >
    <Phone className="w-6 h-6 mb-1" />
    電話する
  </a>
</div>
