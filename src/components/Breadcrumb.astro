---
import { ChevronRight } from 'lucide-react';

interface Props {
  items: { label: string; path?: string }[];
}

const { items } = Astro.props;
---

<nav aria-label="パンくずリスト" class="bg-slate-100 border-b border-slate-200">
  <div class="container mx-auto max-w-4xl px-4 py-3">
    <ol class="flex flex-wrap items-center gap-1 text-sm text-slate-600">
      <li>
        <a href="/" class="hover:text-emerald-700 transition-colors">
          ホーム
        </a>
      </li>
      {items.map((item, i) => (
        <li class="flex items-center gap-1">
          <ChevronRight className="w-3.5 h-3.5 text-slate-400" />
          {i === items.length - 1 ? (
            <span class="text-slate-800 font-medium">{item.label}</span>
          ) : (
            <a
              href={item.path}
              class="hover:text-emerald-700 transition-colors"
            >
              {item.label}
            </a>
          )}
        </li>
      ))}
    </ol>
  </div>
</nav>
