---
interface Props {
  subtitle?: string;
}

const { subtitle } = Astro.props;
---

<div class="text-center mb-12">
  <h2 class="text-3xl md:text-4xl font-bold text-emerald-900 mb-4"><slot /></h2>
  {subtitle && <p class="text-lg text-emerald-700 font-medium">{subtitle}</p>}
  <div class="w-24 h-1 bg-orange-500 mx-auto mt-6 rounded-full"></div>
</div>
