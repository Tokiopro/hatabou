---
import { Phone, Clock, ChevronRight } from 'lucide-react';
import { navItems, secondaryNavItems } from '../data/navigation';
import { areas } from '../data/areas';
import { company } from '../data/company';

const allNavItems = [...navItems, ...secondaryNavItems];
---

<footer class="bg-emerald-950 text-slate-300 py-12 px-4 border-t-4 border-orange-500">
  <div class="container mx-auto max-w-6xl grid md:grid-cols-3 gap-8">
    <div>
      <div class="flex items-center mb-4">
        <img src="/logo.webp" alt="建築鈑金はた" width="40" height="40" class="w-10 h-10 rounded-full object-cover border border-emerald-600 shrink-0 mr-3" />
        <h2 class="text-2xl font-bold text-white">建築鈑金はた</h2>
      </div>
      <p class="mb-4 text-sm leading-relaxed text-slate-400">
        福井県を中心に、屋根・外壁・雨樋のリフォームを行っています。
        築20～30年のコロニアル屋根の「C/guardカバー工法」に強みを持っています。
      </p>
      <div class="flex items-center mt-4 text-slate-300">
        <Phone className="w-5 h-5 mr-2 text-emerald-500" />
        <a href={`tel:${company.phone}`} class="hover:text-white transition-colors">{company.phone}</a>
      </div>
      <div class="flex items-center mt-2 text-slate-300">
        <Clock className="w-5 h-5 mr-2 text-emerald-500" />
        <span>営業時間 8:00〜18:00 (日祝休)</span>
      </div>
    </div>
    <div>
      <h3 class="text-lg font-bold text-white mb-4 border-b border-emerald-800 pb-2">
        メニュー
      </h3>
      <ul class="space-y-3">
        {allNavItems.map((item) => (
          <li>
            <a
              href={item.path}
              class="hover:text-white transition-colors flex items-center text-sm"
            >
              <ChevronRight className="w-4 h-4 mr-1 text-emerald-500" />{' '}
              {item.label}
            </a>
          </li>
        ))}
        <li>
          <a
            href="/contact"
            class="hover:text-white transition-colors flex items-center text-sm"
          >
            <ChevronRight className="w-4 h-4 mr-1 text-emerald-500" />{' '}
            お問い合わせ
          </a>
        </li>
      </ul>
    </div>
    <div>
      <h3 class="text-lg font-bold text-white mb-4 border-b border-emerald-800 pb-2">
        対応エリア
      </h3>
      <ul class="space-y-3">
        {areas.map((area) => (
          <li>
            <a
              href={`/area/${area.slug}`}
              class="hover:text-white transition-colors flex items-center text-sm"
            >
              <ChevronRight className="w-4 h-4 mr-1 text-emerald-500" />{' '}
              {area.name}
            </a>
          </li>
        ))}
      </ul>
      <p class="text-xs text-emerald-500 mt-3">
        ※エリア外の場合もお気軽にご相談ください。
      </p>
    </div>
  </div>
  <div class="text-center mt-12 pt-8 border-t border-emerald-900 text-sm text-slate-400">
    &copy; {new Date().getFullYear()} 建築鈑金はた All Rights Reserved.
  </div>
</footer>
