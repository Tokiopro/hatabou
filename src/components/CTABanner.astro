---
import { Phone, MessageCircle, Mail } from 'lucide-react';
import Button from './Button.astro';
import { company } from '../data/company';

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
const telHref = `tel:${company.phone}`;
---

{compact ? (
  <div class="bg-orange-50 border border-orange-200 rounded-xl p-6 md:p-8 text-center">
    <h3 class="text-xl md:text-2xl font-bold text-emerald-900 mb-4">
      まずはお気軽にご相談ください
    </h3>
    <div class="flex flex-col sm:flex-row justify-center gap-4">
      <Button
        href={telHref}
        class="text-lg py-3 px-8"
      >
        <Phone className="w-5 h-5 mr-2" />
        {company.phone}
      </Button>
      <Button
        variant="line"
        href="/contact"
        class="text-lg py-3 px-8"
      >
        <MessageCircle className="w-5 h-5 mr-2" />
        LINEで相談
      </Button>
    </div>
  </div>
) : (
  <section class="py-16 px-4">
    <div class="container mx-auto max-w-4xl">
      <div class="text-center bg-white p-8 md:p-12 rounded-3xl shadow-xl border-t-8 border-orange-500">
        <h3 class="text-2xl md:text-3xl font-bold text-emerald-900 mb-6">
          まずは、お気軽にご相談ください
        </h3>
        <p class="text-lg text-slate-700 mb-10">
          「ちょっと見てもらうだけ」「見積もりだけ」でも大歓迎です。
          <br />
          福井県内の皆様の住まいを、適正価格でしっかりお守りします。
        </p>
        <div class="flex flex-col md:flex-row justify-center gap-6">
          <Button
            href={telHref}
            class="w-full md:w-auto text-xl py-5 px-10 shadow-orange-500/50"
          >
            <Phone className="w-5 h-5 mr-2" />
            {company.phone}
            <br />
            <span class="text-sm font-normal">
              （営業時間 8:00〜18:00 日祝休）
            </span>
          </Button>
          <Button
            variant="line"
            href="/contact"
            class="w-full md:w-auto text-xl py-5 px-10"
          >
            <MessageCircle className="w-5 h-5 mr-2" />
            LINEで写真を送る
            <br />
            <span class="text-sm font-normal">（24時間受付中）</span>
          </Button>
        </div>
        <div class="mt-8">
          <a
            href="/contact"
            class="text-emerald-700 font-bold underline hover:text-emerald-900 inline-flex items-center justify-center transition-colors"
          >
            <Mail className="w-5 h-5 mr-2" /> メール・見積フォームはこちら
          </a>
        </div>
      </div>
    </div>
  </section>
)}
